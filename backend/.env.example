## Node Environment
NODE_ENV=development

## Server Port
PORT=3000

## Database Configuration
## Option 1: Using DATABASE_URL (Recommended for Railway)
## Format: postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://user:password@localhost:5432/neto_db

## Option 2: Individual database variables (Alternative)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=neto_db

## JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_minimo_32_caracteres
JWT_EXPIRATION=7d

## CORS Configuration
## List of allowed origins separated by commas
CORS_ORIGIN=http://localhost:5500,http://localhost:3000,http://localhost:8080
